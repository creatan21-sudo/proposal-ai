{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "gunicorn app:app --bind 0.0.0.0:$PORT --workers 1 --threads 16 --timeout 600 --max-requests 1000 --max-requests-jitter 100",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "volumes": [
    {
      "mountPath": "/app/data"
    }
  ]
}
